{
  "manifest_version": 3,
  "name": "AI Chat Hub",
  "version": "1.6",
  "description": "Access multiple AI assistants in Chrome's side panel via a persistent tab bar. Includes a built-in Gemini API chat and per-site quality-of-life tweaks.",
  "permissions": [
    "sidePanel",
    "storage",
    "contextMenus",
    "declarativeNetRequest"
  ],
  "host_permissions": [
    "https://generativelanguage.googleapis.com/*",
    "https://*.google.com/*",
    "https://*.googleusercontent.com/*",
    "https://*.gstatic.com/*",
    "https://consent.google.com/*",
    "https://accounts.google.com/*",
    "https://gemini.google.com/*",
    "https://chatgpt.com/*",
    "https://*.openai.com/*",
    "https://auth0.openai.com/*",
    "https://cdn.oaistatic.com/*",
    "https://perplexity.ai/*",
    "https://*.perplexity.ai/*",
    "https://copilot.microsoft.com/*",
    "https://*.microsoft.com/*",
    "https://*.microsoftonline.com/*",
    "https://*.live.com/*",
    "https://claude.ai/*",
    "https://*.anthropic.com/*",
    "https://*.claude.ai/*",
    "https://grok.com/*",
    "https://*.x.com/*",
    "https://x.com/*",
    "https://*.x.ai/*",
    "https://www.meta.ai/*",
    "https://*.meta.ai/*",
    "https://meta.ai/*",
    "https://*.facebook.com/*",
    "https://facebook.com/*",
    "https://*.meta.com/*",
    "https://meta.com/*",
    "https://chat.deepseek.com/*",
    "https://*.deepseek.com/*",
    "https://deepseek.com/*",
    "https://chat.mistral.ai/*",
    "https://*.mistral.ai/*",
    "https://mistral.ai/*",
    "https://poe.com/*",
    "https://*.poe.com/*",
    "https://you.com/*",
    "https://*.you.com/*",
    "https://chat.qwen.ai/*",
    "https://*.qwen.ai/*",
    "https://qwen.ai/*",
    "https://tongyi.aliyun.com/*",
    "https://*.aliyun.com/*",
    "https://www.kimi.com/*",
    "https://*.kimi.com/*",
    "https://kimi.com/*",
    "https://*.moonshot.cn/*",
    "https://kimi.moonshot.cn/*",
    "https://chat.z.ai/*",
    "https://*.z.ai/*",
    "https://z.ai/*",
    "https://www.genspark.ai/*",
    "https://*.genspark.ai/*",
    "https://genspark.ai/*"
  ],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "ruleset_1",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  },
  "content_scripts": [
    {
      "matches": ["https://gemini.google.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Open AI Chat Hub"
  }
}
